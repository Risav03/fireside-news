# Copy to `.env` (repo root) and/or `apps/server/.env`. Do not commit real secrets.

# Text-to-speech (OpenAI). Replaces former `ELEVENLABS_API_KEY` and `ELEVENLABS_VOICE_ID`.
OPENAI_API_KEY=

# Optional TTS tuning (defaults shown):
# OPENAI_TTS_MODEL=tts-1-hd
# OPENAI_TTS_VOICE=onyx
# OPENAI_TTS_SPEED=1

DATABASE_URL=
REDIS_URL=
ANTHROPIC_API_KEY=

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Optional CDN prefix for uploaded audio URLs
# CDN_BASE_URL=
