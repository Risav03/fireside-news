{
  "name": "fireside-news",
  "private": true,
  "packageManager": "bun@1.3.5",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "npm run start --workspace=@repo/server",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "bun --filter @repo/db db:generate",
    "db:migrate": "bun --filter @repo/db db:migrate"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
